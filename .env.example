
# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava
QWEN_VISION_MODEL=qwen2-vl

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Database (for audit trail)
DATABASE_URL=sqlite:///./claims_audit.db

# Model
MODEL_PATH=model/artifacts/xgboost_model.json
FRAUD_THRESHOLD_PASS=0.3
FRAUD_THRESHOLD_FAIL=0.7

API_KEY_PRIMARY=
API_KEY_SECONDARY=

# Vision Provider: gemini, ollama, qwen, tesseract
VISION_PROVIDER=gemini
VISION_MODEL=gemini-3-flash-preview

# Database (for audit trail)
DATABASE_URL=sqlite:///./claims_audit.db

MONGODB_URI=
MONGODB_DB_NAME=ginja_claims
